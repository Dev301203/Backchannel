{
  "name": "backchannel-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backchannel realtime chat backend: WebSocket fanout over Redis pub/sub, Postgres persistence, Better Auth.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "tsx src/db/migrate.ts && tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --clean",
    "start:dist": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "smoketest": "node smoketest.mjs",
    "migrate": "tsx src/db/migrate.ts",
    "auth:generate": "better-auth generate --output src/auth/schema.sql"
  },
  "dependencies": {
    "better-auth": "^1.2.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "tldts": "^6.1.71",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
