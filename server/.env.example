# ---------------------------------------------------------------------------
# Backchannel server configuration
# Copy to .env for local dev. In production, inject via your secret manager.
# ---------------------------------------------------------------------------

# HTTP + WebSocket listen port (both share one server)
PORT=8080

# Comma-separated list this node advertises to logs / health. Optional.
NODE_ID=

# Public base URL of the API (used by Better Auth for callbacks + cookies)
BASE_URL=http://localhost:8080

# --- Postgres -------------------------------------------------------------
# Point at pgbouncer in production, not Postgres directly.
DATABASE_URL=postgres://backchannel:backchannel@localhost:5432/backchannel

# --- Fanout / presence / rate-limit driver --------------------------------
# 'memory' = single-instance, in-process (no Redis needed; great for free tier)
# 'redis'  = multi-instance fanout via Redis pub/sub
# Leave PUBSUB_DRIVER unset to auto-pick: redis if REDIS_URL is set, else memory.
PUBSUB_DRIVER=
# Only needed when the driver resolves to 'redis'.
REDIS_URL=redis://localhost:6379
# For very large scale, Redis 7 sharded pub/sub (SPUBLISH/SSUBSCRIBE).
USE_SHARDED_PUBSUB=false

# --- Auth (Better Auth) ---------------------------------------------------
# Generate a strong random secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=dev-only-insecure-secret-change-me
BETTER_AUTH_URL=http://localhost:8080

# Extension origin(s) allowed to call auth + API with credentials.
# Chrome extension origins look like chrome-extension://<id>
# Comma-separated. During dev you can add http://localhost:5173 etc.
TRUSTED_ORIGINS=chrome-extension://EXTENSION_ID_HERE

# Optional social login. Leave blank to disable a provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Limits / moderation --------------------------------------------------
# Message rate limit: max messages per window per user.
RATE_LIMIT_MSGS=5
RATE_LIMIT_WINDOW_SEC=5
# Longer burst guard.
RATE_LIMIT_MSGS_MIN=30

# History backfill size cap
MAX_HISTORY=100

# Presence heartbeat: how often each node refreshes its room counts (ms)
PRESENCE_HEARTBEAT_MS=15000
PRESENCE_TTL_SEC=45
